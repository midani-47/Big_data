}
}
print("Feature normalization completed.")
# Handle missing values - KNN cannot work with NA values
print("Handling missing values for KNN compatibility...")
# Check for NA values before handling
na_count_train_before <- sum(is.na(knn_train_data[, feature_cols, with=FALSE]))
na_count_test_before <- sum(is.na(knn_test_data[, feature_cols, with=FALSE]))
print(paste("NA values before handling - Train:", na_count_train_before, "Test:", na_count_test_before))
# Handle NA values by imputation with median/mode
for (col in feature_cols) {
# For training data
if (sum(is.na(knn_train_data[[col]])) > 0) {
if (is.numeric(knn_train_data[[col]])) {
# Use median for numeric features
median_val <- median(knn_train_data[[col]], na.rm = TRUE)
knn_train_data[is.na(get(col)), (col) := median_val]
} else {
# Use mode for categorical features (though we converted them to numeric)
mode_val <- as.numeric(names(sort(table(knn_train_data[[col]]), decreasing = TRUE))[1])
knn_train_data[is.na(get(col)), (col) := mode_val]
}
}
# For test data - use same imputation values from training data
if (sum(is.na(knn_test_data[[col]])) > 0) {
if (is.numeric(knn_test_data[[col]])) {
# Use median from training data
median_val <- median(knn_train_data[[col]], na.rm = TRUE)
knn_test_data[is.na(get(col)), (col) := median_val]
} else {
# Use mode from training data
mode_val <- as.numeric(names(sort(table(knn_train_data[[col]]), decreasing = TRUE))[1])
knn_test_data[is.na(get(col)), (col) := mode_val]
}
}
}
# Verify NA handling
na_count_train_after <- sum(is.na(knn_train_data[, feature_cols, with=FALSE]))
na_count_test_after <- sum(is.na(knn_test_data[, feature_cols, with=FALSE]))
print(paste("NA values after handling - Train:", na_count_train_after, "Test:", na_count_test_after))
print("Missing value handling completed.")
# Prepare feature matrices
train_features_knn <- as.matrix(knn_train_data[, feature_cols, with=FALSE])
test_features_knn <- as.matrix(knn_test_data[, feature_cols, with=FALSE])
train_labels_knn <- knn_train_data$class
# Final data quality check
print("Final data quality check after all preprocessing:")
print(paste("Training data - NA values:", sum(is.na(train_features_knn))))
print(paste("Test data - NA values:", sum(is.na(test_features_knn))))
print(paste("Training data - Infinite values:", sum(is.infinite(train_features_knn))))
print(paste("Test data - Infinite values:", sum(is.infinite(test_features_knn))))
print(paste("Training labels - levels:", length(levels(train_labels_knn))))
print(paste("Feature matrix dimensions - Train:", paste(dim(train_features_knn), collapse=" x "), "Test:", paste(dim(test_features_knn), collapse=" x ")))
if (sum(is.na(train_features_knn)) == 0 && sum(is.na(test_features_knn)) == 0) {
print("✓ Data is clean and ready for KNN")
} else {
print("✗ Data still contains missing values")
}
print("KNN preprocessing completed successfully.")
# Train and evaluate KNN
print("=== KNN EVALUATION ===")
# KNN doesn't have a separate training phase - it's a lazy learner
# We'll test different k values and use k=5 as a reasonable choice
k_value <- 5
print(paste("Using k =", k_value, "for KNN classification"))
# Handle potential memory/computational issues by sampling if dataset is too large
max_samples <- 10000  # Reasonable limit for KNN
if (nrow(train_features_knn) > max_samples) {
print(paste("Dataset too large for KNN, sampling", max_samples, "training samples"))
set.seed(42)
sample_indices <- sample(nrow(train_features_knn), max_samples)
train_features_knn_sampled <- train_features_knn[sample_indices, ]
train_labels_knn_sampled <- train_labels_knn[sample_indices]
} else {
train_features_knn_sampled <- train_features_knn
train_labels_knn_sampled <- train_labels_knn
}
print("Making predictions with KNN...")
tryCatch({
# Make predictions
pred_knn <- knn(
train = train_features_knn_sampled,
test = test_features_knn,
cl = train_labels_knn_sampled,
k = k_value
)
print("KNN predictions completed successfully.")
}, error = function(e) {
print("Error in KNN prediction:")
print(e$message)
# Try with smaller dataset or different approach
