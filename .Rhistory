balanced_train_final <- rbindlist(balanced_train_list)
# Debug: Check what we actually got
cat("\n**Debug: Checking combined data structure...**\n")
cat("- Total rows after combining:", nrow(balanced_train_final), "\n")
cat("- Column names:", paste(names(balanced_train_final), collapse=", "), "\n")
# Check for any data integrity issues
if (nrow(balanced_train_final) == 0) {
cat("**ERROR: No data in balanced_train_final!**\n")
cat("**Checking individual class lists:**\n")
for (cls_name in names(balanced_train_list)) {
cat("- ", cls_name, ": ", nrow(balanced_train_list[[cls_name]]), " rows\n", sep="")
}
}
