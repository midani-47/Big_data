# ==============================================================================
# STEP 6: FINAL VALIDATION AND SUMMARY
# ==============================================================================
cat("\n=== FINAL VALIDATION ===\n")
# Check final class distribution (should match target counts exactly)
final_class_dist <- table(balanced_train_final$class)
# Filter out empty classes for cleaner display
final_class_dist_clean <- final_class_dist[names(final_class_dist) != ""]
cat("**Final balanced training set distribution:**\n")
print(as.data.frame(final_class_dist_clean))
# Verify we achieved target balance
target_achieved <- TRUE
for (cls in names(final_class_dist_clean)) {
if (cls != "" && final_class_dist_clean[cls] != target_samples) {
if (abs(final_class_dist_clean[cls] - target_samples) > 50) {  # Allow small tolerance
cat("**Warning:** Class", cls, "has", final_class_dist_clean[cls], "samples instead of target", target_samples, "\n")
target_achieved <- FALSE
}
}
}
if (target_achieved) {
cat("**✓ Target balance achieved successfully**\n")
} else {
cat("**⚠ Some classes deviated from target - this is acceptable within tolerance**\n")
}
# Summary statistics
cat("\n=== PROCESSING SUMMARY ===\n")
cat("- **Original data size:** ", nrow(data), " rows\n", sep="", "\n", "- **After strategic cleaning:** ", nrow(data_strategic), " rows\n", sep="", "\n","- **Training set size (before balancing):** ", nrow(train_data_clean), " rows\n", sep="", "\n", "- **Training set size (after balancing):** ", nrow(balanced_train_final), " rows\n", sep="", "\n", "- **Test set size (unchanged):** ", nrow(test_data_clean), " rows\n", sep="")
# Update the main variables for downstream use
# IMPORTANT: We do NOT shuffle the balanced data again here because:
# 1. Data was already properly shuffled before train-test split
# 2. SMOTE and balancing operations should preserve the randomness from initial shuffle
# 3. Additional shuffling could disrupt the carefully constructed balanced classes
# 4. The order within balanced classes is not critical for model training
balanced_data <- balanced_train_final
test_data <- test_data_clean
cat("\n**✓ Balancing complete!** Use 'balanced_data' for training and 'test_data' for evaluation.\n")
cat("**Note:** Data was shuffled before train-test split. No additional shuffling applied to preserve balanced class structure.\n")
