smaller_sample <- min(5000, nrow(train_features_knn_sampled))
sample_indices_small <- sample(nrow(train_features_knn_sampled), smaller_sample)
pred_knn <<- knn(
train = train_features_knn_sampled[sample_indices_small, ],
test = test_features_knn,
cl = train_labels_knn_sampled[sample_indices_small],
k = min(k_value, smaller_sample - 1)
)
print("KNN with smaller sample completed.")
})
print("Predicted class distribution:")
