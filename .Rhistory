min_val <- min(knn_train_data[[col]], na.rm = TRUE)
max_val <- max(knn_train_data[[col]], na.rm = TRUE)
# Avoid division by zero
if (max_val != min_val) {
# Normalize training data
knn_train_data[[col]] <- (knn_train_data[[col]] - min_val) / (max_val - min_val)
# Normalize test data using same parameters
knn_test_data[[col]] <- (knn_test_data[[col]] - min_val) / (max_val - min_val)
}
}
}
